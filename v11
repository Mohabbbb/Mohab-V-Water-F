<script>
// ── CALCULATION ENGINE ────────────────────────────
const calcModel=(ov={})=>{
  const sl={...S.sl,...ov};const exr=Math.max(1,sl.exrate);
  const acts=S.skus.filter(s=>s.active);const totHrs=sl.hrs*sl.days;const util=sl.util/100;const lf=1-sl.loss/100;
  const totMix=acts.reduce((a,s)=>a+s.mix,0)||1;
  const cxBase=S.cx.filter(r=>r.c!=="Contingency").reduce((a,r)=>a+r.a,0);
  const cxCont=cxBase*.05;const totCx=cxBase+cxCont;
  const totOx=S.ox.reduce((a,r)=>a+r.a,0);const wc=totOx*sl.wcMonths;const totInv=totCx+wc;
  const hrPay=S.hr.reduce((a,r)=>a+r.cnt*r.sal,0);
  const skuR=acts.map(sk=>{
    const mf=sk.mix/totMix;const gb=sk.speed*totHrs*util*mf;const nb=gb*lf;
    const rmCost=S.rm.filter(r=>r.sku===sk.name||r.sku==="all").reduce((a,r)=>a+r.usd,0);
    const pkgSYP=rmCost*exr;const oxPerB=nb>0?(totOx*exr)/nb:0;
    const rev=nb*sk.price;const cogs=nb*(pkgSYP+oxPerB);const gp=rev-cogs;const gm=rev>0?gp/rev*100:0;
    return{...sk,mf,gb,nb,rmCost,pkgSYP,oxPerB,rev,cogs,gp,gm};
  });
  const totNb=skuR.reduce((a,s)=>a+s.nb,0);const totRev=skuR.reduce((a,s)=>a+s.rev,0);
  const totCogs=skuR.reduce((a,s)=>a+s.cogs,0);const gp=totRev-totCogs;const gm=totRev>0?gp/totRev*100:0;
  const tax=Math.max(0,gp*sl.tax/100);const netProfit=gp-tax;const nm=totRev>0?netProfit/totRev*100:0;
  const bP=totNb>0?totRev/totNb:0;const bV=totNb>0?totCogs/totNb:0;const cm=bP-bV;
  const fixC=totOx*exr;const beBtl=cm>0?fixC/cm:0;const beRev=beBtl*bP;const sfty=totRev>0?(totRev-beRev)/totRev*100:0;
  const loan=totInv*(1-sl.finEq/100);const eq=totInv*sl.finEq/100;
  const mRate=sl.finInt/100/12;const totM=sl.finYrs*12;const grace=Math.min(sl.finGrace,totM-1);
  let mpay=0;
  if(loan>0&&mRate>0&&totM>grace){const n=totM-grace;mpay=loan*mRate*Math.pow(1+mRate,n)/(Math.pow(1+mRate,n)-1)}
  const annDebt=mpay*12;const dscr=annDebt>0?netProfit*12/annDebt:99;
  let amort=[],bal=loan;
  for(let m=1;m<=totM&&bal>1;m++){const ip=bal*mRate;const pp=m<=grace?0:Math.min(mpay-ip,bal);bal-=pp;amort.push({m,ip,pp,pay:m<=grace?ip:mpay,bal:Math.max(0,bal)})}
  const ramp=[.4,.6,.78,.9,1,1,1,1,1,1];let cumCF=0,cf10=[];
  for(let y=0;y<10;y++){
    const esc=Math.pow(1+sl.priceEsc/100,y);const r=ramp[y];
    const rev_y=totRev*12*r*esc;const np_y=Math.max(0,(gp-tax)*12*r);const debt_y=y<sl.finYrs?annDebt:0;
    const cf_y=np_y-debt_y;cumCF+=cf_y;const disc=cf_y/Math.pow(1+sl.discount/100,y+1);
    cf10.push({y:y+1,r,rev:rev_y,np:np_y,cf:cf_y,cum:cumCF,disc,debt:debt_y});
  }
  const npv10=cf10.reduce((a,c)=>a+c.disc,0)-totInv;
  let irr10=0;try{let lo=-.99,hi=50;for(let i=0;i<100;i++){const mid=(lo+hi)/2;const v=cf10.reduce((a,c,i2)=>a+c.cf/Math.pow(1+mid,i2+1),0)-totInv;if(Math.abs(v)<1)break;v>0?lo=mid:hi=mid}irr10=(lo+hi)/2*100}catch(_){}
  let payback=0,cp=0;for(const c of cf10){cp+=c.cf;if(cp>=totInv){payback=c.y;break}}if(!payback)payback=cf10.length+1;
  return{sl,exr,acts,skuR,totHrs,totNb,totCx,cxBase,cxCont,wc,totInv,totOx,hrPay,totRev,totCogs,gp,gm,tax,netProfit,nm,bP,bV,cm,beBtl,beRev,sfty,loan,eq,mpay,annDebt,dscr,amort,cf10,npv10,irr10,payback};
};

