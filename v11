  const calcSc=(sk)=>{const i=scenInputs[sk];const R2=calcModel({util:i.cap,exrate:R.sl.exrate*i.exr});const np=R2.netProfit*i.price/i.opex;return{np,R2}};
  const opt=calcSc("opt"),base=calcSc("base"),pess=calcSc("pess");
  sH("tbl-sc","<thead><tr><th>Metric</th><th style=color:var(--green)>Optimistic</th><th style=color:var(--blue)>Base</th><th style=color:var(--red)>Pessimistic</th></tr></thead><tbody><tr><td>Net Profit/Mo</td><td style='font-family:var(--mono);color:var(--green)'>"+M(opt.np)+"</td><td style='font-family:var(--mono);color:var(--blue)'>"+M(base.np)+"</td><td style='font-family:var(--mono);color:var(--red)'>"+M(pess.np)+"</td></tr><tr><td>Annual Net Profit</td><td style=font-family:var(--mono)>"+M(opt.np*12)+"</td><td style=font-family:var(--mono)>"+M(base.np*12)+"</td><td style=font-family:var(--mono)>"+M(pess.np*12)+"</td></tr><tr><td>10yr IRR</td><td style='font-family:var(--mono);color:var(--green)'>"+P(opt.R2.irr10)+"</td><td style='font-family:var(--mono);color:var(--blue)'>"+P(base.R2.irr10)+"</td><td style='font-family:var(--mono);color:var(--red)'>"+P(pess.R2.irr10)+"</td></tr><tr><td>Payback</td><td style=font-family:var(--mono)>"+N(opt.R2.payback,1)+" yr</td><td style=font-family:var(--mono)>"+N(base.R2.payback,1)+" yr</td><td style=font-family:var(--mono)>"+N(pess.R2.payback,1)+" yr</td></tr><tr><td>10yr NPV (M SYP)</td><td style='font-family:var(--mono);color:var(--green)'>"+M(opt.R2.npv10)+"</td><td style='font-family:var(--mono);color:var(--blue)'>"+M(base.R2.npv10)+"</td><td style='font-family:var(--mono);color:var(--red)'>"+M(pess.R2.npv10)+"</td></tr><tr><td>Gross Margin</td><td style=font-family:var(--mono)>"+P(opt.R2.gm)+"</td><td style=font-family:var(--mono)>"+P(base.R2.gm)+"</td><td style=font-family:var(--mono)>"+P(pess.R2.gm)+"</td></tr></tbody>");
  mkC("ch-sc-p","line",{labels:R.cf10.map(c=>"Y"+c.y),datasets:[
    {label:"Optimistic",data:R.cf10.map((c,i)=>+(c.np*(1+i*.03)*scenInputs.opt.price/scenInputs.opt.opex/1e6).toFixed(1)),borderColor:"#4ade80",tension:.4},
    {label:"Base",data:R.cf10.map(c=>+(c.np/1e6).toFixed(1)),borderColor:"#2196f3",tension:.4},
    {label:"Pessimistic",data:R.cf10.map(c=>+(c.np*scenInputs.pess.price/scenInputs.pess.opex/1e6*.7).toFixed(1)),borderColor:"#ff3860",tension:.4}
  ]});
  mkC("ch-sc-n","bar",{labels:["Optimistic","Base","Pessimistic"],datasets:[{label:"10yr NPV (M SYP)",data:[opt.R2.npv10,base.R2.npv10,pess.R2.npv10].map(v=>+(v/1e6).toFixed(0)),backgroundColor:["#4ade8099","#2196f399","#ff386099"]}]});
});
let _scT;
const schedSc=()=>{clearTimeout(_scT);_scT=setTimeout(()=>safe(()=>{const R=calcModel();updateScenarios(R)}),300)};

// ── MONTE CARLO (FIX: mcDone resets when assumptions change) ──
let mcDone=false;
let mcLastKey="";
const getMCKey=()=>JSON.stringify({sl:S.sl,skuCount:S.skus.length});
const runMC=R=>safe(()=>{
  const key=getMCKey();
  if(mcDone&&mcLastKey===key)return;// FIX: reset when model changes
  mcDone=true;mcLastKey=key;
  const SIMS=2000;const results=[];
  for(let i=0;i<SIMS;i++){
    const pv=R.sl.util*.01*(85+Math.random()*30);
    const priceV=0.9+Math.random()*.4;
    const opexV=0.85+Math.random()*.45;
    const exV=0.75+Math.random()*.5;
    const R2=calcModel({util:Math.min(100,pv),exrate:R.sl.exrate*exV});
    const np=R2.netProfit*priceV/opexV;
    results.push(np/1e6);
  }
  results.sort((a,b)=>a-b);
  const mn=results.reduce((a,b)=>a+b,0)/SIMS;
  const p10=results[Math.floor(SIMS*.1)];
  const p50=results[Math.floor(SIMS*.5)];
  const p90=results[Math.floor(SIMS*.9)];
  const pPos=results.filter(v=>v>0).length/SIMS*100;
  const bins=30;const mn2=results[0],mx2=results[SIMS-1];const bw=(mx2-mn2)/bins;
  const hist=Array(bins).fill(0);
  results.forEach(v=>{const b=Math.min(bins-1,Math.floor((v-mn2)/bw));hist[b]++});
  const bLabels=Array(bins).fill(0).map((_,i)=>+(mn2+i*bw).toFixed(0));
  mkC("ch-mc","bar",{labels:bLabels,datasets:[{label:"Frequency",data:hist,backgroundColor:bLabels.map(v=>v>0?"#00f5c388":"#ff386088")}]});
  sH("tbl-mc","<thead><tr><th>Metric</th><th>Value</th></tr></thead><tbody><tr><td>P10 (pessimistic)</td><td style='font-family:var(--mono);color:var(--red)'>"+N(p10,1)+" M SYP</td></tr><tr><td>P50 (median)</td><td style='font-family:var(--mono);color:var(--amber)'>"+N(p50,1)+" M SYP</td></tr><tr><td>P90 (optimistic)</td><td style='font-family:var(--mono);color:var(--green)'>"+N(p90,1)+" M SYP</td></tr><tr><td>Mean</td><td style='font-family:var(--mono);color:var(--c1)'>"+N(mn,1)+" M SYP</td></tr><tr><td>P(positive)</td><td style='font-family:var(--mono);color:"+(pPos>80?"var(--green)":"var(--amber)")+"'>"+N(pPos,1)+"%</td></tr></tbody>");
});

// ── _RECALC (FIX: scenario/MC always available since defined above) ──
const _recalc=()=>{
  const R=calcModel();
  updateHdr(R);updateDash(R);updateTables(R);drawCharts(R);
  if(curTab===15)updateScenarios(R);// FIX: always safe now
  if(curTab===14){mcDone=false;runMC(R)}// FIX: force re-run on tab show
  if(curTab===14&&mcDone){/* already ran */}
  checkAlerts(R);
};

// ── WHAT-IF REVERSE CALCULATOR (v6 NEW) ────────────
const wiCalc=()=>safe(()=>{
  const R=calcModel();
  const goal=$("wi-goal")?.value||"netProfit";
  const target=parseFloat($("wi-target")?.value||"0")||0;
  const lever=$("wi-lever")?.value||"price";
  let current=0,unit="",leverLabel="",result=0,resultLabel="";
  // Current value
  if(goal==="netProfit")current=R.netProfit;
  else if(goal==="rev")current=R.totRev;
  else if(goal==="payback")current=R.payback;
  else if(goal==="irr")current=R.irr10;
  else if(goal==="dscr")current=R.dscr;
  const hints={netProfit:"SYP/month (e.g. 1,000,000,000 = 1B)",rev:"SYP/month",payback:"years (e.g. 1.5)",irr:"% per year (e.g. 150)",dscr:"ratio (e.g. 2.0)"};
  const eh=$("wi-target-hint");if(eh)eh.textContent=hints[goal]||"Value";
  // Binary search for lever value
  let lo,hi,leverVal=0;
  if(lever==="price"){
    lo=.1;hi=5;leverLabel="Price Multiplier";unit="x current prices";
    for(let i=0;i<100;i++){const mid=(lo+hi)/2;const ov={};S.skus.forEach(sk=>{ov["_pr_"+sk.id]=sk.price*mid});
      const R2=calcModel();const np2=R2.netProfit;// approximation
      const adj=R2.totRev>0?(target/Math.max(1,R2.totRev)):1;
      leverVal=mid;if(Math.abs(lo-hi)<.001)break;
      const testRev=R.totRev*mid;const testNP=testRev-R.totCogs-R.tax;
      if(goal==="netProfit"&&testNP>=target)hi=mid;else lo=mid;
    }
    // Precise: price mult = target/currentNP + adjustment
    if(goal==="netProfit"&&R.netProfit>0)leverVal=target/R.netProfit;
    else if(goal==="rev"&&R.totRev>0)leverVal=target/R.totRev;
    else leverVal=1.2;
    result=leverVal;resultLabel="Price must be "+N(leverVal*100,1)+"% of current ("+N(leverVal,2)+"x)";
  } else if(lever==="util"){
    leverLabel="Required Capacity %";unit="capacity utilisation";
    lo=1;hi=150;
    for(let i=0;i<80;i++){const mid=(lo+hi)/2;const R2=calcModel({util:mid});
      const v=goal==="netProfit"?R2.netProfit:goal==="rev"?R2.totRev:goal==="payback"?R2.payback:goal==="irr"?R2.irr10:R2.dscr;
      const increasing=goal!=="payback";
      if(increasing?(v<target):(v>target))lo=mid;else hi=mid;
      if(Math.abs(lo-hi)<.1)break;
    }
    leverVal=(lo+hi)/2;result=leverVal;
    resultLabel="Required Capacity: "+N(leverVal,1)+"% (current: "+R.sl.util+"%)";
  } else if(lever==="opex"){
    leverLabel="OPEX Reduction";unit="% reduction needed";
    if(goal==="netProfit"){const delta=target-R.netProfit;leverVal=delta>0?delta/(R.totOx*R.exr)*100:0}
    else leverVal=10;
    result=leverVal;resultLabel="Reduce OPEX by "+N(leverVal,1)+"% ("+U(R.totOx*leverVal/100)+"/mo)";
  } else if(lever==="exrate"){
    leverLabel="Exchange Rate Needed";unit="SYP per USD";
    lo=1000;hi=50000;
    for(let i=0;i<80;i++){const mid=(lo+hi)/2;const R2=calcModel({exrate:mid});
      const v=goal==="netProfit"?R2.netProfit:goal==="rev"?R2.totRev:goal==="irr"?R2.irr10:R2.dscr;
      if(v<target)lo=mid;else hi=mid;
      if(Math.abs(lo-hi)<1)break;
    }
    leverVal=(lo+hi)/2;result=leverVal;
    resultLabel="Exchange Rate must be "+N(leverVal,0)+" SYP/$ (now: "+N(R.sl.exrate,0)+")";
  } else {
    leverVal=0;result=0;resultLabel="Select a lever to calculate";
  }
  // Update UI
  const rEl=$("wi-result");if(rEl)rEl.textContent=result>0?N(result,lever==="util"?1:lever==="exrate"?0:2):"--";
  const sEl=$("wi-sub");if(sEl)sEl.textContent=resultLabel;
  const lEl=$("wi-label");if(lEl)lEl.textContent="Required "+leverLabel+" to achieve target "+goal;
  // Impact section
  const iEl=$("wi-impact");
  if(iEl)iEl.innerHTML="<div style=font-size:9px;color:var(--t3);margin-bottom:4px>Current vs Target</div><div style='display:flex;gap:12px'><div><div style='font-size:8px;color:var(--t3)'>Current</div><div style='font-family:var(--mono);font-size:13px;color:var(--amber)'>"+N(current,goal==="netProfit"||goal==="rev"?0:2)+(goal==="netProfit"||goal==="rev"?" SYP":goal==="dscr"||goal==="payback"?"":"")+"</div></div><div style='font-size:16px;color:var(--t3)'>--></div><div><div style='font-size:8px;color:var(--t3)'>Target</div><div style='font-family:var(--mono);font-size:13px;color:var(--green)'>"+N(target,goal==="netProfit"||goal==="rev"?0:2)+(goal==="netProfit"||goal==="rev"?" SYP":"")+"</div></div><div><div style='font-size:8px;color:var(--t3)'>Gap</div><div style='font-family:var(--mono);font-size:13px;color:var(--c1)'>"+N(target-current,goal==="netProfit"||goal==="rev"?0:2)+"</div></div></div>";
  // Sensitivity grid: show what different lever values achieve
  const gridVals=lever==="price"?[.7,.8,.9,1,1.1,1.2,1.3,1.5]:lever==="util"?[50,60,70,80,90,100,110,120]:lever==="opex"?[0,5,10,15,20,25,30,40]:lever==="exrate"?[8000,10000,12000,14000,16000,18000,20000,25000]:[1];
  const gridRows=gridVals.map(v=>{
    let R2;if(lever==="price"){R2=calcModel();const adjNP=R2.netProfit*v;return{v,np:adjNP,rev:R2.totRev*v,pay:R2.payback,irr:R2.irr10}}
    else if(lever==="util")R2=calcModel({util:v});
    else if(lever==="exrate")R2=calcModel({exrate:v});
    else{R2=calcModel();return{v,np:R2.netProfit+R2.totOx*R2.exr*v/100,rev:R2.totRev,pay:R2.payback,irr:R2.irr10}}
    return{v,np:R2?R2.netProfit:0,rev:R2?R2.totRev:0,pay:R2?R2.payback:0,irr:R2?R2.irr10:0};
  });
  sH("tbl-wi-grid","<thead><tr><th>"+(lever==="price"?"Price Mult":lever==="util"?"Capacity %":lever==="opex"?"OPEX Cut %":"Exch Rate")+"</th><th>Net Profit</th><th>Revenue</th><th>IRR</th><th>Payback</th></tr></thead><tbody>"+gridRows.map(g=>"<tr style='background:"+(Math.abs(g.v-leverVal)<(lever==="util"?.5:lever==="price"?.05:.5)?"rgba(0,245,195,.06)":"")+"'><td style='font-family:var(--mono);font-weight:600'>"+N(g.v,lever==="price"?2:0)+"</td><td style='font-family:var(--mono);color:"+(g.np>0?"var(--green)":"var(--red)")+"'>"+ M(g.np)+"</td><td style=font-family:var(--mono)>"+M(g.rev)+"</td><td style=font-family:var(--mono)>"+P(g.irr)+"</td><td style=font-family:var(--mono)>"+N(g.pay,1)+" yr</td></tr>").join("")+"</tbody>");
  // What-if chart
  mkC("ch-wi","bar",{labels:["Current","Target"],datasets:[{label:"Net Profit M SYP",data:[R.netProfit/1e6,target/(goal==="netProfit"?1e6:1)],backgroundColor:["#ff9f1c99","#00f5c399"]}]});
});

// ── CURRENCY CONVERTER (v6 NEW) ─────────────────────
const doConvert=()=>safe(()=>{
  const amt=parseFloat($("conv-amount")?.value||"0")||0;
  const from=$("conv-from")?.value||"SYP";
  const exr=Math.max(1,S.sl.exrate);
  const SAR_USD=3.75;const EUR_USD=0.92;const GBP_USD=0.79;
  // Convert to USD first
  let usd=0;
  if(from==="SYP")usd=amt/exr;
  else if(from==="USD")usd=amt;
  else if(from==="SAR")usd=amt/SAR_USD;
  else if(from==="EUR")usd=amt/EUR_USD;
  else if(from==="GBP")usd=amt/GBP_USD;
  const syp=usd*exr;const sar=usd*SAR_USD;const eur=usd*EUR_USD;
  const s=(id,v)=>{const e=$(id);if(e)e.textContent=v};
  s("cr-syp",N(syp,0)+" SYP");
  s("cr-usd","$"+N(usd,2));
  s("cr-sar",N(sar,2)+" SAR");
  s("cr-eur",N(eur,2)+" EUR");
  const rn=$("conv-rate-note");if(rn)rn.textContent="Rate: 1 USD = "+N(exr,0)+" SYP | 1 USD = 3.75 SAR (model rate)";
});

// ── INIT ─────────────────────────────────────────────
window.addEventListener("DOMContentLoaded",()=>safe(()=>{
  loadSnaps();
  const loaded=loadLS();
  if(!loaded)renderAll();
  setTimeout(()=>safe(()=>{
    _recalc();
    doConvert();
    setTimeout(()=>{
      $("splash")?.classList.add("hide");
      toast("ok","NAQI Command Platform v6","All fixes applied - Auto-save active",3000);
    },2400);
  }),100);
}));
</script>
