    el.innerHTML+="<div style='margin-top:10px;padding-top:8px;border-top:1px solid var(--b2)'><div style='font-family:var(--mono);font-size:12px;color:var(--c1)'>"+M(np)+" SYP/mo</div><div style='font-size:8.5px;color:var(--t2);margin-top:2px'>Net Profit - IRR: "+P(R2.irr10)+" - Payback: "+N(R2.payback,1)+" yr</div></div>";
  };
