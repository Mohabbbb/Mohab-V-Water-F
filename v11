  s("k-hr4",P(R.hrPay/Math.max(1,R.totOx)*100));
  // Production KPIs
  s("k-p1",N(R.totNb));s("k-p2",N(R.totHrs));s("k-p2s",R.sl.hrs+" hrs/day x "+R.sl.days+" days");
  s("k-p3",R.totNb>0?N(R.totCogs/R.totNb)+" SYP":"--");s("k-p4",P(R.gm));
  // BE KPIs
  s("k-be1",N(R.beBtl,0));s("k-be1s",P(R.beBtl/Math.max(1,R.totNb)*100)+" of capacity");
  s("k-be2",M(R.beRev));s("k-be2s",U(R.beRev/R.exr));
  s("k-be3",N(R.cm)+" SYP");s("k-be4",P(R.sfty));
  // CF KPIs
  s("k-cf1",U(R.totInv));s("k-cf1s",SYP(R.totInv*R.exr));s("k-cf2",N(R.payback,1)+" years");
  s("k-cf3",P(R.irr10));s("k-cf4",M(R.npv10));s("k-cf4s",U(R.npv10/R.exr)+" USD");
  // Ops KPIs
  const totBtlDay=R.skuR.reduce((a,s)=>a+s.nb/R.sl.days,0);s("k-op1",N(totBtlDay,0));
});
