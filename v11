const inlineEdit=(span,arr,id,field)=>safe(()=>{
  if(span._editing)return;span._editing=true;
  const obj=S[arr]?.find(x=>x.id==id);if(!obj)return;
  const orig=span.textContent;
  span.innerHTML="<input class=ixs value="+(obj[field]||0)+" type=number step=any style='width:80px;border:1px solid var(--c1);background:var(--bg2);font-family:var(--mono);font-size:10px;padding:2px 4px'>" ;
  const inp=span.querySelector("input");inp.focus();inp.select();
  const commit=()=>{
    const v=parseFloat(inp.value);
    if(!isNaN(v)){pushUndo();obj[field]=v}
    span._editing=false;span.textContent=isNaN(v)?orig:N(v,0);
    scheduleSave();recalc();
    if(arr==="mkt"){renderMktRows();const R=calcModel();drawMktChart(R);}// FIX: always update chart
  };
  inp.onblur=commit;inp.onkeydown=e=>{if(e.key==="Enter")inp.blur();if(e.key==="Escape"){span._editing=false;span.textContent=orig}};
});

