<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>NAQI Command Platform v6</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{--bg0:#020b16;--bg1:#050d1a;--bg2:#091220;--bg3:#0d1829;--bg4:#111e33;--b1:#132338;--b2:#1a2f4a;--b3:#21405f;--t1:#eef6ff;--t2:#aacae8;--t3:#5a8ab5;--t4:#2d5070;--c1:#00f5c3;--c2:#2196f3;--c3:#ff9f1c;--c4:#ff3860;--c5:#a855f7;--c6:#4ade80;--c7:#06b6d4;--c8:#f97316;--c9:#ec4899;--c10:#84cc16;--green:#4ade80;--amber:#ff9f1c;--red:#ff3860;--blue:#2196f3;--card1:rgba(9,18,32,.9);--card2:rgba(13,24,41,.95);--display:'Syne',sans-serif;--mono:'Space Mono',monospace;--body:'Inter',sans-serif}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg0);color:var(--t1);font-family:var(--body);font-size:13px;min-height:100vh;overflow-x:hidden}

/* SPLASH */
#splash{position:fixed;inset:0;background:var(--bg0);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .6s}
#splash.hide{opacity:0;pointer-events:none}
.sp-logo{font-size:48px;margin-bottom:8px}
.sp-title{font-family:var(--display);font-size:26px;font-weight:800;background:linear-gradient(135deg,var(--c1),var(--c6),var(--c2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sp-sub{font-size:11px;color:var(--t3);letter-spacing:2px;text-transform:uppercase;margin-top:4px}
.sp-bar{width:300px;height:3px;background:var(--b2);border-radius:2px;margin-top:28px;overflow:hidden}
.sp-fill{height:100%;background:linear-gradient(90deg,var(--c1),var(--c6));border-radius:2px;animation:spf 2.4s ease-out forwards}
@keyframes spf{from{width:0}to{width:100%}}
.sp-feats{display:flex;flex-wrap:wrap;gap:8px;margin-top:20px;justify-content:center;max-width:420px}
.sp-feat{font-size:9px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--t2);background:var(--b1);border:1px solid var(--b2);padding:4px 10px;border-radius:20px}

/* TOPBAR */
#topbar{position:sticky;top:0;z-index:100;background:rgba(2,11,22,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--b2);padding:0 16px;display:flex;align-items:center;gap:12px;height:52px}
.tb-mark{font-size:22px}
.tb-name{font-family:var(--display);font-size:14px;font-weight:800;background:linear-gradient(135deg,var(--c1),var(--c2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;white-space:nowrap}
.tb-sub{font-size:8px;color:var(--t3);letter-spacing:1px;white-space:nowrap}
.tb-div{width:1px;height:30px;background:var(--b2);flex-shrink:0}
.tb-kpis{display:flex;gap:6px;flex:1;overflow-x:auto;scrollbar-width:none}
.tb-kpis::-webkit-scrollbar{display:none}
.tb-kpi{background:var(--bg3);border:1px solid var(--b2);border-radius:8px;padding:4px 9px;white-space:nowrap;min-width:100px}
.tb-kpi-l{font-size:7.5px;color:var(--t3);letter-spacing:.5px;text-transform:uppercase}
.tb-kpi-v{font-family:var(--mono);font-size:10.5px;font-weight:700;color:var(--c1)}

/* MULTI-CURRENCY BADGE */
.curr-badge{font-size:8px;color:var(--t3);font-family:var(--mono)}

.save-ind{display:flex;align-items:center;gap:5px;font-size:9px;color:var(--t3);white-space:nowrap}
.save-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 5px var(--green)}
.save-dot.saving{background:var(--amber);animation:pulse .7s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

.tb-acts{display:flex;gap:5px;align-items:center}

/* UNDO BAR */
#undo-bar{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);background:var(--card2);border:1px solid var(--b2);border-radius:30px;padding:7px 14px;font-size:10px;display:flex;gap:10px;align-items:center;z-index:500;opacity:0;transition:opacity .3s;pointer-events:none;box-shadow:0 4px 16px rgba(0,0,0,.4)}
#undo-bar.show{opacity:1;pointer-events:all}

/* TABBAR */
#tabbar{background:var(--bg1);border-bottom:1px solid var(--b1);padding:0 16px;display:flex;gap:1px;overflow-x:auto;scrollbar-width:none;position:sticky;top:52px;z-index:90}
#tabbar::-webkit-scrollbar{display:none}
.tab{padding:10px 13px;font-family:var(--body);font-size:10.5px;font-weight:500;color:var(--t3);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all .2s}
.tab:hover{color:var(--t2)}
.tab.active{color:var(--c1);border-bottom-color:var(--c1)}
.tnew{font-size:7px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;background:linear-gradient(135deg,var(--c1),var(--c6));color:#000;padding:1px 4px;border-radius:2px;margin-left:3px;vertical-align:middle}
.tbadge{display:inline-block;background:var(--b2);color:var(--t3);font-size:8px;font-weight:600;padding:1px 5px;border-radius:8px;margin-left:3px}

/* MAIN */
#main{min-height:calc(100vh - 104px)}
.page{display:none;padding:18px;max-width:1700px;margin:0 auto}
.page.active{display:block}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
.gc2{display:grid;grid-template-columns:2fr 1fr;gap:14px}
.gc3{display:grid;grid-template-columns:2fr 1fr 1fr;gap:14px}
.mb{margin-bottom:14px}

/* CARDS */
.card{background:var(--card1);border:1px solid var(--b2);border-radius:10px;padding:14px}
.c-tl{border-top:2px solid var(--c1)}
.c-bl{border-top:2px solid var(--blue)}
.c-am{border-top:2px solid var(--amber)}
.c-gn{border-top:2px solid var(--green)}
.c-pu{border-top:2px solid var(--c5)}
.c-rd{border-top:2px solid var(--red)}
.c-cy{border-top:2px solid var(--c7)}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:8px}
.card-title{font-family:var(--display);font-size:11.5px;font-weight:700;color:var(--t1)}

/* SECTION HEADER */
.sec{display:flex;align-items:center;gap:10px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--b1)}
.acc{font-family:var(--display);font-size:17px;font-weight:800;background:linear-gradient(135deg,var(--t1),var(--t2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* KPI CARDS */
.kpi{background:var(--bg3);border:1px solid var(--b2);border-radius:10px;padding:13px 15px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kc1::before{background:linear-gradient(90deg,var(--c1),var(--c7))}
.kc2::before{background:linear-gradient(90deg,var(--blue),var(--c7))}
.kc3::before{background:linear-gradient(90deg,var(--amber),var(--c8))}
.kc5::before{background:linear-gradient(90deg,var(--c5),var(--c9))}
.kc6::before{background:linear-gradient(90deg,var(--green),var(--c1))}
.kl{font-size:8.5px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--t3);margin-bottom:5px}
.kv{font-family:var(--mono);font-size:20px;font-weight:700;color:var(--c1);line-height:1.1}
.ks{font-size:8.5px;color:var(--t3);margin-top:3px}
.kpi-mc{display:flex;gap:6px;margin-top:5px;flex-wrap:wrap}
.kpi-curr{font-size:8px;font-family:var(--mono);color:var(--t4);background:var(--b1);padding:2px 6px;border-radius:3px}

/* TABLES */
.tw{overflow-x:auto}
.tbl{width:100%;border-collapse:collapse;font-size:11px}
.tbl th{background:var(--bg3);color:var(--t3);font-weight:600;font-size:9px;letter-spacing:.5px;text-transform:uppercase;padding:7px 9px;text-align:left;border-bottom:1px solid var(--b2)}
.tbl td{padding:6px 9px;border-bottom:1px solid var(--b1);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:var(--bg3)}
.tbl tr.tt td{background:var(--bg3);font-weight:600;border-top:1px solid var(--b2)}
.h220{max-height:220px;overflow-y:auto}
.h280{max-height:280px;overflow-y:auto}
.h340{max-height:340px;overflow-y:auto}
.h400{max-height:400px;overflow-y:auto}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:6px 11px;border-radius:7px;border:none;cursor:pointer;font-family:var(--body);font-size:10.5px;font-weight:500;transition:all .18s;white-space:nowrap}
.btn-xs{padding:3px 7px;font-size:9.5px}
.btn-sm{padding:4px 9px;font-size:10px}
.btn-icon{padding:6px 8px}
.btl{background:var(--c1);color:#000;font-weight:700}
.btl:hover{filter:brightness(1.1)}
.bsc{background:var(--b2);color:var(--t2)}
.bsc:hover{background:var(--b3)}
.bpr{background:rgba(0,245,195,.1);color:var(--c1);border:1px solid rgba(0,245,195,.2)}
.bpr:hover{background:rgba(0,245,195,.18)}
.berr{background:rgba(255,56,96,.1);color:var(--red);border:1px solid rgba(255,56,96,.2)}
.berr:hover{background:rgba(255,56,96,.18)}
.bgr{background:rgba(74,222,128,.1);color:var(--green);border:1px solid rgba(74,222,128,.2)}
.bpu{background:rgba(168,85,247,.1);color:var(--c5);border:1px solid rgba(168,85,247,.2)}
.bamb{background:rgba(255,159,28,.1);color:var(--amber);border:1px solid rgba(255,159,28,.2)}
.btn-add{display:flex;align-items:center;gap:6px;padding:7px 11px;background:rgba(0,245,195,.06);border:1px dashed rgba(0,245,195,.25);border-radius:7px;color:var(--c1);font-size:10.5px;cursor:pointer;width:100%;transition:all .18s;font-family:var(--body)}
.btn-add:hover{background:rgba(0,245,195,.12)}
.btn-rm{background:none;border:none;color:var(--t4);cursor:pointer;padding:3px 5px;border-radius:4px;font-size:13px;line-height:1;transition:all .18s}
.btn-rm:hover{color:var(--red);background:rgba(255,56,96,.1)}

/* INPUTS */
.inp,.sel,.ixs{background:var(--bg3);border:1px solid var(--b2);border-radius:6px;color:var(--t1);font-family:var(--body);font-size:11px;padding:6px 9px;width:100%;transition:border-color .18s;outline:none}
.inp:focus,.sel:focus,.ixs:focus{border-color:var(--c1)}
.ixs{background:transparent;border:1px solid transparent;border-radius:4px;padding:2px 5px}
.ixs:hover{border-color:var(--b2);background:var(--bg3)}
.ixs:focus{border-color:var(--c1);background:var(--bg3)}

/* BADGES */
.bdg{display:inline-block;padding:2px 7px;border-radius:20px;font-size:8.5px;font-weight:600;letter-spacing:.3px}
.btl.bdg,.bdg.btl{background:rgba(0,245,195,.15);color:var(--c1)}
.bok{background:rgba(74,222,128,.15);color:var(--green)}
.bwarn{background:rgba(255,159,28,.15);color:var(--amber)}
.berr.bdg,.bdg.berr{background:rgba(255,56,96,.15);color:var(--red)}
.binfo{background:rgba(33,150,243,.15);color:var(--blue)}
.bpu.bdg,.bdg.bpu{background:rgba(168,85,247,.15);color:var(--c5)}

/* CHARTS */
.cw{position:relative;height:200px}
.cw-tall{height:260px}
.cw-sm{height:150px}
.cw canvas{max-height:100%}

/* CALLOUTS */
.cl{font-size:10.5px;color:var(--t2);background:var(--bg3);border-radius:8px;padding:10px 13px;line-height:1.5}
.cl-info{border-left:3px solid var(--blue)}
.cl-ok{border-left:3px solid var(--green)}
.cl-warn{border-left:3px solid var(--amber)}

/* SEPARATORS */
.sep{height:1px;background:var(--b1);margin:12px 0}

/* DRILLDOWNS */
.dh{display:flex;gap:6px;align-items:center;font-size:8px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--t3);padding:5px 2px;border-bottom:1px solid var(--b1);margin-bottom:2px}
.dh.cx,.dh.ox{grid-template-columns:none}
.dh span,.dh div{flex:1}
.dr-tot{font-family:var(--mono);font-size:10.5px;font-weight:700;color:var(--c1);padding:7px 4px;border-top:1px solid var(--b2);margin-top:4px}
.drg-row{display:flex;gap:5px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.drg-row:last-child{border-bottom:none}
.drg-sk{display:grid;grid-template-columns:1fr .5fr .8fr .5fr 1fr .7fr .7fr 30px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.drg-mkt{display:grid;grid-template-columns:.6fr .5fr .8fr .8fr .8fr .8fr .5fr 1fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.drg-cond{display:grid;grid-template-columns:1.2fr .6fr .5fr .5fr 1fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.drg-comp-p{display:grid;grid-template-columns:.8fr 1fr .5fr .7fr .7fr 1fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.drg-rfq{display:grid;grid-template-columns:90px 1fr 1fr 70px 70px 70px 85px 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.dh.mkt{grid-template-columns:.6fr .5fr .8fr .8fr .8fr .8fr .5fr 1fr 28px;display:grid}
.dh.cond{grid-template-columns:1.2fr .6fr .5fr .5fr 1fr 28px;display:grid}
.dh.comp-p{grid-template-columns:.8fr 1fr .5fr .7fr .7fr 1fr 28px;display:grid}
.dh.rfq{grid-template-columns:90px 1fr 1fr 70px 70px 70px 85px 28px;display:grid}
.dh.ord{grid-template-columns:60px 1.2fr .8fr .5fr .9fr .8fr 28px;display:grid}
.drg-ord{display:grid;grid-template-columns:60px 1.2fr .8fr .5fr .9fr .8fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.dh.hr{grid-template-columns:1.5fr .8fr .4fr .7fr .7fr 28px;display:grid}
.drg-hr{display:grid;grid-template-columns:1.5fr .8fr .4fr .7fr .7fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.dh.cx{grid-template-columns:2fr .8fr .8fr .8fr 28px;display:grid}
.drg-cx{display:grid;grid-template-columns:2fr .8fr .8fr .8fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.dh.ox{grid-template-columns:2fr .8fr .8fr .8fr 28px;display:grid}
.drg-ox{display:grid;grid-template-columns:2fr .8fr .8fr .8fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.dh.rm{grid-template-columns:2fr .7fr .7fr .7fr .7fr 28px;display:grid}
.drg-rm{display:grid;grid-template-columns:2fr .7fr .7fr .7fr .7fr 28px;gap:4px;align-items:center;padding:4px 0;border-bottom:1px solid var(--b1)}
.dh.sk{grid-template-columns:1fr .5fr .8fr .5fr 1fr .7fr .7fr 30px;display:grid}

/* SLIDERS */
.slrow{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.sllbl{font-size:9.5px;color:var(--t2);min-width:140px}
.slinp{flex:1;-webkit-appearance:none;height:3px;border-radius:2px;background:var(--b2);outline:none;cursor:pointer}
.slinp::-webkit-slider-thumb{-webkit-appearance:none;width:13px;height:13px;border-radius:50%;background:var(--c1);cursor:pointer;box-shadow:0 0 5px rgba(0,245,195,.5)}
.slval{font-family:var(--mono);font-size:9px;color:var(--c1);min-width:60px;text-align:right}

/* TOASTS */
#toasts{position:fixed;top:58px;right:14px;z-index:999;display:flex;flex-direction:column;gap:7px;max-width:300px}
.toast{background:var(--card2);border:1px solid var(--b2);border-radius:10px;padding:9px 12px;display:flex;align-items:flex-start;gap:8px;box-shadow:0 4px 18px rgba(0,0,0,.5);animation:toIn .3s ease;border-left:3px solid}
.toast.ok{border-left-color:var(--green)}.toast.warn{border-left-color:var(--amber)}.toast.err{border-left-color:var(--red)}.toast.info{border-left-color:var(--blue)}
@keyframes toIn{from{opacity:0;transform:translateX(14px)}to{opacity:1;transform:translateX(0)}}
.toast-body{flex:1}.toast-t{font-size:10px;font-weight:600;margin-bottom:1px}.toast-m{font-size:8.5px;color:var(--t2)}
.toast-x{background:none;border:none;color:var(--t3);cursor:pointer;font-size:13px;flex-shrink:0}

/* MODALS */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(5px);z-index:800;display:none;align-items:center;justify-content:center}
.modal-ov.show{display:flex}
.modal{background:var(--bg2);border:1px solid var(--b2);border-radius:14px;padding:22px;min-width:320px;max-width:620px;max-height:82vh;overflow-y:auto;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.6)}
.modal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;font-family:var(--display);font-size:14px;font-weight:700}

/* SUP CARD */
.sup-card{background:var(--bg3);border:1px solid var(--b2);border-radius:10px;padding:13px;margin-bottom:9px}

/* SWOT */
.swot-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.swot-s,.swot-w,.swot-o,.swot-t{border-radius:10px;padding:12px}
.swot-s{background:rgba(74,222,128,.05);border:1px solid rgba(74,222,128,.17)}
.swot-w{background:rgba(255,56,96,.05);border:1px solid rgba(255,56,96,.17)}
.swot-o{background:rgba(33,150,243,.05);border:1px solid rgba(33,150,243,.17)}
.swot-t{background:rgba(255,159,28,.05);border:1px solid rgba(255,159,28,.17)}
.swot-title{font-family:var(--display);font-size:10.5px;font-weight:700;margin-bottom:8px;display:flex;align-items:center;gap:5px}
.swot-item{font-size:10px;color:var(--t1);margin-bottom:4px;display:flex;gap:5px}
.swot-item::before{content:"›";color:var(--t3);flex-shrink:0}

/* DSCR */
.dscr-box{border-radius:10px;padding:14px;border:2px solid;text-align:center}
.dscr-ok{background:rgba(74,222,128,.06);border-color:rgba(74,222,128,.35)}
.dscr-warn{background:rgba(255,159,28,.06);border-color:rgba(255,159,28,.35)}
.dscr-bad{background:rgba(255,56,96,.06);border-color:rgba(255,56,96,.35)}

/* MIX BADGE */
.mix-bdg{font-size:8px;padding:2px 6px;border-radius:8px;font-weight:600;margin-left:6px;display:inline-flex}

/* SNAP ITEM */
.snap-item{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid var(--b1)}
.snap-item:last-child{border-bottom:none}

/* WHAT-IF PANEL (v6 NEW) */
.whatif-box{background:linear-gradient(135deg,rgba(0,245,195,.04),rgba(33,150,243,.04));border:1px solid rgba(0,245,195,.15);border-radius:10px;padding:16px}
.whatif-result{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--c6);margin:8px 0 4px;line-height:1}
.whatif-sub{font-size:9px;color:var(--t3)}
.whatif-row{display:flex;gap:10px;align-items:center;margin-bottom:10px}
.whatif-lbl{font-size:10px;color:var(--t2);min-width:160px}

/* CURRENCY CONVERTER (v6 NEW) */
.conv-panel{background:var(--bg3);border:1px solid var(--b2);border-radius:10px;padding:14px}
.conv-inp-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.conv-flag{font-size:20px}
.conv-amount{font-family:var(--mono);font-size:14px;font-weight:700}
.conv-currency{font-size:9px;color:var(--t3);letter-spacing:.5px}
.conv-result{background:var(--bg2);border-radius:8px;padding:10px 12px;margin-top:8px}
.conv-res-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--b1)}
.conv-res-row:last-child{border-bottom:none}
.conv-res-val{font-family:var(--mono);font-size:13px;font-weight:700;color:var(--c1)}
.conv-res-lbl{font-size:9px;color:var(--t3)}

/* PRINT (v6 ENHANCED) */
@media print{
  #splash,#topbar,#tabbar,#toasts,#undo-bar,.modal-ov,.btn-add,.btn-rm,.btn{display:none!important}
  .page{display:block!important;page-break-inside:avoid}
  body{background:#fff;color:#111;font-size:11px}
  .card{border:1px solid #ccc;background:#f8f9fa;break-inside:avoid}
  .kpi{border:1px solid #ddd;background:#f0f0f0}
  .tbl th{background:#e9ecef;color:#495057}
  .tbl td{color:#212529}
  :root{--t1:#212529;--t2:#495057;--t3:#868e96;--bg0:#fff;--bg1:#fff;--bg2:#f8f9fa;--bg3:#e9ecef;--b1:#dee2e6;--b2:#ced4da;--c1:#0066cc;--c6:#1a7a3c;--amber:#b35900}
  .g2,.g3,.g4,.g5{grid-template-columns:1fr 1fr}
  .g5{grid-template-columns:repeat(3,1fr)}
  h2,.acc{color:#212529!important;-webkit-text-fill-color:#212529!important}
}

/* MISC */
@media(max-width:900px){.g4{grid-template-columns:1fr 1fr}.g5{grid-template-columns:1fr 1fr}.gc2,.gc3{grid-template-columns:1fr}}
@media(max-width:600px){.g2,.g3,.g4,.g5{grid-template-columns:1fr}.tb-kpis{display:none}}
::-webkit-scrollbar{width:4px;height:4px}::-webkit-scrollbar-track{background:var(--bg1)}::-webkit-scrollbar-thumb{background:var(--b3);border-radius:3px}
</style>
